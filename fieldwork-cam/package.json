{
  "name": "fieldwork-cam",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "apps/services/*",
    "packages/*"
  ],
  "scripts": {
    "gateway": "npm run dev --workspace=api-gateway",
    "auth": "npm run dev --workspace=auth-service",
    "user": "npm run dev --workspace=user-service",
    "project": "npm run dev --workspace=project-service",
    "notification": "npm run dev --workspace=notification-service",
    "media": "npm run dev --workspace=media-service",
    "ai": "npm run dev --workspace=ai-service",
    "report": "npm run dev --workspace=report-service",
    "billing": "npm run dev --workspace=billing-service",
    "submission": "npm run dev --workspace=submission-service"
  },
  "dependencies": {
    "nodemon": "^3.1.14"
  }
}
